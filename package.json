{
  "name": "l0-worker",
  "version": "0.1.0",
  "description": "Stateless, deterministic execution substrate for L0 data plane",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:vercel": "vercel dev",
    "dev:standalone": "bun run src/server.ts",
    "build": "tsc",
    "build:desktop": "bun build ./src/server.ts --compile --outfile dist/l0-worker",
    "test": "vitest --exclude src/e2e/**",
    "test:run": "vitest run --exclude src/e2e/**",
    "test:e2e": "vitest run --dir src/e2e",
    "test:all": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "@ai2070/l0": "^0.22.0",
    "ai": "^6.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vercel/node": "^5.5.16",
    "dotenv": "^17.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vercel": "^50.1.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
