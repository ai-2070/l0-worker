# Worker Configuration
# WORKER_ID=l0-dev
MAX_CONCURRENCY=1

# Auth (required in production, optional for local dev)
L0_AUTH_SECRET=your-shared-secret-with-l1-min-32-chars

# Serverless Timeout (optional, 0 = disabled)
FUNCTION_TIMEOUT_MS=0
DRAIN_BUFFER_MS=5000

# Provider API Keys
OPENAI_API_KEY=sk-...
