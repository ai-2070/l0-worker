# Deployment preset (local or vercel)
# Auto-detected on Vercel via VERCEL env var
# DEPLOYMENT=vercel

# Worker Configuration (overrides preset defaults)
# WORKER_ID=l0-dev
# MAX_CONCURRENCY=4

# Auth (required in production, optional for local dev)
L0_AUTH_SECRET=your-shared-secret-with-l1-min-32-chars

# Serverless Timeout (overrides preset defaults)
# Local default: 0 (disabled), Vercel default: 60000 (60s)
# FUNCTION_TIMEOUT_MS=60000
# DRAIN_BUFFER_MS=5000

# Provider API Keys
OPENAI_API_KEY=sk-...
